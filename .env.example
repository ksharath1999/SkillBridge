# -------------------------------
# DATABASE CONFIGURATION
# -------------------------------
# PostgreSQL (Neon / production)
DATABASE_URL=postgresql://username:password@host:port/database

# Example (Neon format):
# DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-1.aws.neon.tech/dbname?sslmode=require


# -------------------------------
# AUTH CONFIGURATION
# -------------------------------
# Secret key for JWT (replace with strong random string)
SECRET_KEY=your_super_secret_key_here


# -------------------------------
# MONITORING API KEY
# -------------------------------
# Used by Monitoring Officer endpoints
MONITORING_API_KEY=12345


# -------------------------------
# OPTIONAL (LOCAL DEV)
# -------------------------------
# Uncomment to use SQLite instead of PostgreSQL
# DATABASE_URL=sqlite:///./test.db